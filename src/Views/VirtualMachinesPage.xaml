<Page
    x:Class="ExHyperV.Views.Pages.VirtualMachinesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:properties="clr-namespace:ExHyperV.Properties"
    xmlns:converters="clr-namespace:ExHyperV.Converters"
    xmlns:tools="clr-namespace:ExHyperV.Tools"
    xmlns:components="clr-namespace:ExHyperV.Views.Components"
    Title="VirtualMachinesPage" mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1100"
    tools:ScrollHelper.LockParentScroll="True"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
    x:Name="RootPage">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:VmNameToIconConverter x:Key="VmNameToIconConverter" />
        <converters:OsTypeToImageConverter x:Key="OsTypeToImageConverter" />



        
        
        <!-- 保底界面模板：未选择虚拟机时显示 -->
        <DataTemplate x:Key="VmEmptyStateTemplate">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Opacity="0.6">
                    <TextBlock Text="{x:Static properties:Resources.Label_NoVmSelected}" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,8"/>
                    <TextBlock Text="{x:Static properties:Resources.Label_SelectVmStart}" 
                       FontSize="14"
                       HorizontalAlignment="Center" 
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- [新增] 纯白/纯空模板：用于创建模式下的底层占位 -->
        <DataTemplate x:Key="VmBlankTemplate">
            <Grid Background="Transparent"/>
        </DataTemplate>

        <DataTemplate x:Key="VmListItemTemplate">
            <Border Background="Transparent" Padding="2,6" 
            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                          Command="{Binding DataContext.RenameVmCommand, ElementName=RootPage}" 
                          CommandParameter="{Binding}" />
                </Border.InputBindings>
                
                <Border.ContextMenu>
                    <ContextMenu>
                        <ui:MenuItem Header="{x:Static properties:Resources.VmPage_MenuOpenFolder}"
             Command="{Binding PlacementTarget.Tag.OpenVmFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
             CommandParameter="{Binding}">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" />
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>
                        <Separator/>
                        
                        <!-- 重命名选项 -->
                        <ui:MenuItem Header="{x:Static properties:Resources.Xaml_Rename}" 
                             Command="{Binding PlacementTarget.Tag.RenameVmCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                             CommandParameter="{Binding}">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Rename24" />
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>

                        <Separator/>
                        <ui:MenuItem Header="{x:Static properties:Resources.VmPage_ErrOptimizeFailed}"
             Command="{Binding PlacementTarget.Tag.PurgeVmCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
             CommandParameter="{Binding}"
             Foreground="{ui:ThemeResource SystemFillColorCriticalBrush}">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="DeleteDismiss24" Foreground="{ui:ThemeResource SystemFillColorCriticalBrush}"/>
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>
                        
                        <!-- 删除选项 (重新添加) -->
                        <ui:MenuItem Header="{x:Static properties:Resources.Xaml_Delete}" 
                             Command="{Binding PlacementTarget.Tag.DeleteVmCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                             CommandParameter="{Binding}"
                             Foreground="{ui:ThemeResource SystemFillColorCriticalBrush}">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Delete24" Foreground="{ui:ThemeResource SystemFillColorCriticalBrush}" />
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <!-- 此处保持你现在的 Grid 内容不变（状态点、图标、名字区域等） -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="6" Height="6" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Background" Value="{ui:ThemeResource SystemFillColorSuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <ui:FontIcon Grid.Column="1" FontFamily="{DynamicResource SegoeFluentIcons}" 
                         Glyph="{Binding Name, Converter={StaticResource VmNameToIconConverter}}" 
                         FontSize="16" Margin="0,0,8,0"
                         Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                    <Grid Grid.Column="2">
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" 
                           TextTrimming="CharacterEllipsis" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:TextBox Text="{Binding EditedName, UpdateSourceTrigger=PropertyChanged}"
                            tools:FocusHelper.IsFocused="{Binding IsEditing}"
                            FontSize="12" MinHeight="24" Padding="4,2" Margin="-4,0,0,0">
                            <ui:TextBox.Style>
                                <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBox.Style>
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding DataContext.CommitRenameCommand, ElementName=RootPage}" CommandParameter="{Binding}"/>
                                <KeyBinding Key="Esc" Command="{Binding DataContext.CancelRenameCommand, ElementName=RootPage}" CommandParameter="{Binding}"/>
                            </ui:TextBox.InputBindings>
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="LostFocus">
                                    <i:InvokeCommandAction Command="{Binding DataContext.CommitRenameCommand, ElementName=RootPage}" CommandParameter="{Binding}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </ui:TextBox>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="VmDetailTemplate">
            <Grid x:Name="DetailRootGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="24,12,24,0" 
                Background="{ui:ThemeResource ControlFillColorSecondaryBrush}" 
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="24" MinHeight="160">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 监视器/图标容器 -->
                        <Grid Grid.Column="0" Width="120" Height="100" VerticalAlignment="Center">
                            <!-- 1. 默认 OS 图标 (关机时显示)  -->
                            <Image RenderOptions.BitmapScalingMode="HighQuality"
                           Width="100" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="{Binding OsType, Converter={StaticResource OsTypeToImageConverter}}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>

                            <!-- 2. 实时监视器 (运行时显示) -->
                            <Border Background="Black" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="4,4,4,8" CornerRadius="2" ClipToBounds="True"
                            ToolTip="{x:Static properties:Resources.Label_DoubleClickConnect}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding DataContext.OpenNativeConnectCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                                </Border.InputBindings>
                                <Viewbox Stretch="Uniform">
                                    <Image Source="{Binding Thumbnail}" Width="320" Height="240" 
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                </Viewbox>
                            </Border>
                        </Grid>

                        <!-- 详情区域 -->
                        <Grid Grid.Column="2" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 第一行：名称与按钮 -->
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}" FontSize="28" 
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,16,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button Content="{x:Static properties:Resources.Label_Console}" Icon="Display24" Appearance="Secondary" 
                                               Padding="16,6" Height="36" Margin="0,0,8,0" CornerRadius="8"
                                               Command="{Binding DataContext.OpenNativeConnectCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                                    <Border CornerRadius="8" ClipToBounds="True">
                                        <Grid>
                                            <ui:Button Content="{x:Static properties:Resources.Button_Start}" Icon="Play24" Appearance="Primary" 
                                                       Padding="41,6" Height="36" CornerRadius="8" BorderThickness="0"
                                                       HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                                       Command="{Binding ControlCommand}" 
                                                       CommandParameter="Start">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                            <Grid>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:Button Grid.Column="0" Content="{x:Static properties:Resources.Button_ShutDown}" Icon="Stop24" Appearance="Danger" Foreground="White"
           Padding="24,0" Height="36" CornerRadius="8,0,0,8" BorderThickness="0" Margin="0" VerticalContentAlignment="Center"
           Command="{Binding ControlCommand}" CommandParameter="Stop"/>
                                                <ui:DropDownButton Grid.Column="1" Icon="ChevronDown24" Appearance="Danger" Foreground="White"
                   Padding="6,0,10,0" Height="36" CornerRadius="0,8,8,0" BorderThickness="0" Margin="0" VerticalContentAlignment="Center">
                                                    <ui:DropDownButton.Flyout>
                                                        <ContextMenu>
                                                            <MenuItem Header="{x:Static properties:Resources.Button_Restart}" Icon="{ui:SymbolIcon ArrowCounterclockwise24}"
              Command="{Binding PlacementTarget.DataContext.ControlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
              CommandParameter="Restart"/>
                                                            <MenuItem Header="{x:Static properties:Resources.Button_Pause}" Icon="{ui:SymbolIcon Pause24}"
              Command="{Binding PlacementTarget.DataContext.ControlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
              CommandParameter="Suspend"/>
                                                            <Separator/>
                                                            <MenuItem Header="{x:Static properties:Resources.Button_Save}" Icon="{ui:SymbolIcon Save24}"
              Command="{Binding PlacementTarget.DataContext.ControlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
              CommandParameter="Save"/>
                                                            <MenuItem Header="{x:Static properties:Resources.Button_TurnOff}" Icon="{ui:SymbolIcon Power24}" Foreground="#E81123"
              Command="{Binding PlacementTarget.DataContext.ControlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
              CommandParameter="TurnOff"/>
                                                        </ContextMenu>
                                                    </ui:DropDownButton.Flyout>
                                                </ui:DropDownButton>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- 第二行：状态信息 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <ui:SymbolIcon Symbol="Pulse24" FontSize="16" Margin="0,1,6,0" 
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding State}" FontSize="14" 
                                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,12,0"/>

                                <ui:SymbolIcon Symbol="Timer24" FontSize="16" Margin="0,1,6,0" 
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding Uptime}" FontSize="14" 
                                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>

                            <!-- 第三行：基本配置标签 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" 
                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="10,6" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE81E;" FontSize="14" FontFamily="{DynamicResource SegoeFluentIcons}" Margin="0,1,8,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ConfigSummary}" TextTrimming="CharacterEllipsis" FontSize="13" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" 
                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="10,6" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE8C8;" FontSize="14" FontFamily="{DynamicResource SegoeFluentIcons}" Margin="0,1,8,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="13" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{x:Static properties:Resources.Format_Generation}">
                                                    <Binding Path="Generation" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" 
                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE946;" FontSize="14" FontFamily="{DynamicResource SegoeFluentIcons}" Margin="0,1,8,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="13" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{x:Static properties:Resources.Format_Version}">
                                                    <Binding Path="Version" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 第四行：系统、GPU、IP 标签 -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal">
                                <ComboBox VerticalAlignment="Center"
          ItemsSource="{Binding DataContext.AvailableOsTypes, Source={x:Reference RootPage}}"
          SelectedItem="{Binding OsType, Mode=TwoWay}"
          MaxDropDownHeight="300"
          Padding="10,6,4,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Border Margin="8,0,0,0" VerticalAlignment="Center" 
                                        Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" 
                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="10,6"
                                        ToolTip="{Binding GpuDisplayLabel}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xF211;" FontSize="14" FontFamily="{DynamicResource SegoeFluentIcons}" Margin="0,1,8,0" 
                                                     Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="13" TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding GpuDisplayLabel}"/>
                                                    <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasGpu}" Value="False">
                                                            <Setter Property="Text" Value="{x:Static properties:Resources.Common_None}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Margin="8,0,0,0" VerticalAlignment="Center" 
                                        Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" 
                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="10,6"
                                        ToolTip="{x:Static properties:Resources.Label_CopyIp}">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" 
                                                      Command="{Binding DataContext.CopyToClipboardCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                      CommandParameter="{Binding IpAddress}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xE839;" FontSize="14" FontFamily="{DynamicResource SegoeFluentIcons}" Margin="0,1,8,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{Binding IpAddressDisplay}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="1" Height="1" Fill="{ui:ThemeResource CardStrokeColorDefaultBrush}" Margin="24,12,24,0" Opacity="0.5"/>

                <!-- 视图切换区 -->
                <ContentControl Grid.Row="2" Content="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <components:VmDashboardView/>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="CpuSettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmCpuSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="CpuAffinity">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmCpuAffinityView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="MemorySettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmRAMSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="StorageSettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmStorageSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="AddStorage">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmAddStorageView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="GpuSettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmGPUSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="AddGpuSelect">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmAddGpuSelectView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="AddGpuProgress">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmAddGpuProgressView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="NetworkSettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmNetSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="BootSettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmBootSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.CurrentViewType, RelativeSource={RelativeSource AncestorType=Page}}" Value="SpacetimeSettings">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <components:VmSpacetimeSettingsView/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <!-- 加载遮罩 -->
                <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="100"
              Background="{ui:ThemeResource ApplicationBackgroundBrush}" 
              Visibility="{Binding DataContext.IsLoading, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" Margin="0,0,0,16"/>
                        <TextBlock Text="{x:Static properties:Resources.DataLoading}" 
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 左侧搜索和添加区域 -->
                <Grid Grid.Row="0" Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框容器 -->
                    <Grid Grid.Column="0">
                        <ui:TextBox x:Name="SearchBox"
                PlaceholderText="{x:Static properties:Resources.Placeholder_SearchVm}" 
                ClearButtonEnabled="True" MinHeight="28"
                VerticalContentAlignment="Center"
                Padding="10,0,32,0"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ui:SymbolIcon Symbol="Search24" 
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" 
                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" 
                   IsHitTestVisible="False">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Grid>
                    <!-- 添加按钮 -->
                    <ui:Button Grid.Column="1" 
               Margin="8,0,0,0" 
               Padding="0" 
               Width="24" 
               Height="24"
               Icon="{ui:SymbolIcon Symbol=Add24}"
               Appearance="Secondary"
               ToolTip="{x:Static properties:Resources.Xaml_CreateVm}"
               Command="{Binding CreateVmCommand}"/>
                    <!-- 请确保 ViewModel 中有对应的 Command -->
                </Grid>
                
                <ui:ListView Grid.Row="1" ItemsSource="{Binding VmList}" SelectedItem="{Binding SelectedVm, Mode=TwoWay}" 
                             ItemTemplate="{StaticResource VmListItemTemplate}" Margin="4,0,4,4"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" Background="Transparent"/>

        <Border Grid.Column="2" Background="{ui:ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
            <Grid>
                <!-- 1. 底层视图 -->
                <!-- 移除了原本直接在 ContentControl 上写的 Visibility，改为在 Style 里统一控制 -->
                <ContentControl Content="{Binding SelectedVm}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <!-- 默认状态：显示详情 -->
                            <Setter Property="ContentTemplate" Value="{StaticResource VmDetailTemplate}" />

                            <Style.Triggers>
                                <!-- 逻辑 1 (低优先级): 没有选 VM 时，显示“未选择”文字 -->
                                <DataTrigger Binding="{Binding SelectedVm}" Value="{x:Null}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource VmEmptyStateTemplate}" />
                                </DataTrigger>

                                <!-- 逻辑 2 (高优先级): 正在创建 VM 时，强制显示空白模板 -->
                                <!-- 这样即使 SelectedVm 为空，也不会显示那行字 -->
                                <DataTrigger Binding="{Binding DataContext.IsCreatingVm, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                    <Setter Property="ContentTemplate" Value="{StaticResource VmBlankTemplate}" />
                                    <!--以此确保彻底隐藏，也可以加 Visibility Collapsed，双重保险 -->
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>

                                <!-- 逻辑 3: 加载中隐藏 -->
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <!-- 创建界面-->
                <components:VmCreateView Visibility="{Binding IsCreatingVm, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
        
    </Grid>
</Page>