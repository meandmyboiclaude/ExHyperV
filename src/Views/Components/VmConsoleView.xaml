<UserControl xmlns:properties="clr-namespace:ExHyperV.Properties" 
             x:Class="ExHyperV.Views.Components.VmConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:tools="clr-namespace:ExHyperV.Tools"
             xmlns:converters="clr-namespace:ExHyperV.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Background="Black">
        <tools:MsRdpExHost x:Name="RdpHost" 
        IsVmRunning="{Binding IsRunning}" 
   VmId="{Binding VmId}" 
   IsEnhancedMode="{Binding IsEnhancedMode}" 
   ActualPixelsWidth="{Binding CurrentWidth, Mode=OneWayToSource}"
   ActualPixelsHeight="{Binding CurrentHeight, Mode=OneWayToSource}"
   RequestWidth="{Binding RequestWidth, Mode=TwoWay}"
   RequestHeight="{Binding RequestHeight, Mode=TwoWay}"
   HorizontalAlignment="Center" 
   VerticalAlignment="Center">
        </tools:MsRdpExHost>
        
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" 
              Background="Black" 
              Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="60" Height="60" Margin="0,0,0,20"/>
                <TextBlock Text="{x:Static properties:Resources.VmConsoleView_EstablishingSession}" Foreground="Gray" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>