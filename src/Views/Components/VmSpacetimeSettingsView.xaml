<UserControl xmlns:properties="clr-namespace:ExHyperV.Properties" x:Class="ExHyperV.Views.Components.VmSpacetimeSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:ExHyperV.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="850" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        
        <!-- 完美无缝、边共享正六边形矩阵 -->
        <!-- 计算基准：六边形半径 R = 20 -->
        <!-- 视口宽度 W = R * √3 ≈ 34.64 -->
        <!-- 视口高度 H = R * 3 = 60 -->
        <DrawingBrush x:Key="FineGridBrush" 
              Viewport="0,0,69.28,120" ViewportUnits="Absolute" 
              TileMode="Tile" Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <!-- 所有数值均由原基础值乘以 2 -->
                            <!-- 1. 上部边缘 -->
                            <PathGeometry Figures="M 0,20 L 34.64,0 L 69.28,20" />

                            <!-- 2. 中部边缘 -->
                            <PathGeometry Figures="M 0,60 L 34.64,80 L 69.28,60" />

                            <!-- 3. 三条垂直共享边 -->
                            <PathGeometry Figures="M 0,20 L 0,60" />
                            <!-- 左侧壁 -->
                            <PathGeometry Figures="M 69.28,20 L 69.28,60" />
                            <!-- 右侧壁 -->
                            <PathGeometry Figures="M 34.64,80 L 34.64,120" />
                            <!-- 底部连接支柱 -->
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#14808080" Thickness="1"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:FontIcon Glyph="&#xF738;" FontFamily="{DynamicResource SegoeFluentIcons}" FontSize="24" Margin="0,0,12,0" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_TitleMgmt}" FontSize="20" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>

                <!-- 检查点开关 -->
                <Border BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" 
        BorderThickness="1" CornerRadius="6" Padding="10,4"
        Margin="20,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_LabelCheckpoint}" FontSize="12" 
                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ui:ToggleSwitch IsChecked="{Binding IsCheckpointsEnabled, Mode=TwoWay}" 
                 VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
                            <ui:ToggleSwitch.RenderTransform>
                                <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                            </ui:ToggleSwitch.RenderTransform>
                        </ui:ToggleSwitch>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- 新增：导出按钮 -->
                <ui:Button Appearance="Transparent" Padding="12,8" Margin="0,0,8,0"
           Click="ExportButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnExportTopology}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>

                <!-- 原有返回按钮 -->
                <ui:Button Appearance="Transparent" Padding="8" Command="{Binding GoBackCommand}">
                    <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="18"/>
                </ui:Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：时空流动画布 -->
            <Border Grid.Column="0" Background="{ui:ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,12,0" ClipToBounds="True">
                <Grid x:Name="CanvasContainer" Background="{StaticResource FineGridBrush}" 
      PreviewMouseDown="CanvasContainer_MouseDown" 
      PreviewMouseMove="CanvasContainer_MouseMove" 
      PreviewMouseUp="CanvasContainer_MouseUp" 
      MouseLeave="CanvasContainer_MouseLeave">
                    <!-- 1. 绘图层 -->
                    <ScrollViewer x:Name="SpacetimeScrollViewer" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
                        <Canvas x:Name="SpacetimeCanvas" Width="3000" Height="2000" Background="Transparent"/>
                    </ScrollViewer>

                    <!-- 2. 新增：时空重构遮罩层 (科技感十足) -->
                    <!-- 当 IsLoadingSettings 为 True 时显示 -->
                    <Grid x:Name="ReconstructOverlay" 
              Visibility="{Binding IsLoadingSettings, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="100">
                        <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}" Opacity="0.6"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" 
                                 Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}"/>
                            <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_MsgSyncing}" FontSize="14" Margin="0,16,0,0" 
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <!-- 3. 顶置进度条 (双重反馈) -->
                    <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top" 
                        Visibility="{Binding IsLoadingSettings, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="101"/>
                </Grid>
            </Border>
            
            <!-- 右侧：控制面板 -->
            <StackPanel Grid.Column="1">
                <ui:Card Padding="12">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_LabelDetails}" FontSize="14" FontWeight="Medium" Margin="0,0,0,12"/>
                        <Border Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="6" Padding="12">
                            <Grid>
                                <!-- 1. 未选择提示：默认显示，只有当 SelectedSpacetimeNode 不为 null 时隐藏 -->
                                <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_MsgNoAnchor}" FontSize="12" Opacity="0.4" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <!-- 当选中的节点为空时，显示提示文本 -->
                                                <DataTrigger Binding="{Binding SelectedSpacetimeNode}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 2. 详情内容：默认隐藏，只有当 SelectedSpacetimeNode 不为 null 时显示 -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <!-- 当选中的节点为空时，隐藏详情内容 -->
                                                <DataTrigger Binding="{Binding SelectedSpacetimeNode}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="{Binding SelectedSpacetimeNode.Name}"
                   FontWeight="SemiBold" FontSize="13"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"
                   MaxWidth="130">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <!-- 默认：不可点击 -->
                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                        <Style.Triggers>
                                                            <!-- 快照节点：变成手型，允许点击进入编辑 -->
                                                            <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Snapshot">
                                                                <Setter Property="Cursor" Value="IBeam"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" 
                              Command="{Binding SelectedSpacetimeNode.StartEditCommand}"/>
                                                </TextBlock.InputBindings>
                                            </TextBlock>

                                            <!-- 铅笔图标：仅快照节点显示 -->
                                            <ui:Button Margin="6,0,0,0" Padding="2"
                   Appearance="Transparent"
                   Command="{Binding SelectedSpacetimeNode.StartEditCommand}">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Snapshot">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                                <ui:SymbolIcon Symbol="Edit24" FontSize="12" Opacity="0.6"/>
                                            </ui:Button>
                                        </StackPanel>

                                        <!-- 编辑态 TextBox 保持不变 -->
                                        <ui:TextBox Text="{Binding SelectedSpacetimeNode.EditedName, UpdateSourceTrigger=PropertyChanged}"
                FontSize="12" MinHeight="26" Padding="5,2" Margin="-5,0,0,0"
                VerticalContentAlignment="Center">
                                            <ui:TextBox.Style>
                                                <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:TextBox.Style>
                                            <ui:TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding CommitSpacetimeRenameCommand}"
                        CommandParameter="{Binding SelectedSpacetimeNode}"/>
                                                <KeyBinding Key="Esc" Command="{Binding CancelSpacetimeRenameCommand}"
                        CommandParameter="{Binding SelectedSpacetimeNode}"/>
                                            </ui:TextBox.InputBindings>
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="LostFocus">
                                                    <i:InvokeCommandAction Command="{Binding CommitSpacetimeRenameCommand}"
                                       CommandParameter="{Binding SelectedSpacetimeNode}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </ui:TextBox>
                                    </Grid>
                                    <TextBlock x:Name="SelectedNodeTimeText" Height="16" Text="{Binding SelectedSpacetimeNode.CreatedDate, StringFormat=\{0:yyyy/MM/dd HH:mm:ss\}}" FontSize="11" Opacity="0.6" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_LabelAction}" FontSize="12" Opacity="0.5" Margin="0,16,0,8"/>

                        <!-- 时空模式选择：仅当前节点显示 -->
                        <StackPanel Margin="0,0,0,10">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Current">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- 连续时空 -->
                            <RadioButton Margin="0,0,0,6" GroupName="SpacetimeMode"
                 IsChecked="{Binding SelectedSpacetimeMode, 
                             Converter={StaticResource EnumToBoolConverter}, 
                             ConverterParameter=Continuous}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_TypeContinuous}" FontSize="12" FontWeight="Medium"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_DescContinuous}" 
                       FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- 静止时空 -->
                            <RadioButton GroupName="SpacetimeMode"
                 IsChecked="{Binding SelectedSpacetimeMode, 
                             Converter={StaticResource EnumToBoolConverter}, 
                             ConverterParameter=Still}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_TypeStatic}" FontSize="12" FontWeight="Medium"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_DescStatic}" 
                       FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <!-- A. [当前] 节点特有操作：创建时空 -->
                        <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" 
                                   Command="{Binding CaptureMomentCommand}"
                                   IsEnabled="{Binding IsCheckpointsEnabled}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <!-- 将默认的 Primary 外观放在 Setter 中，使得触发器可以覆盖它 -->
                                    <Setter Property="Appearance" Value="Primary"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Current">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <!-- 当按钮被禁用时，更改外观和前景色，防止文字在灰色背景下不可见 -->
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Appearance" Value="Secondary"/>
                                            <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorDisabledBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24" FontSize="16"/>
                                <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnCreate}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                        
                        <!-- B. [快照] 节点特有操作区：正常态 vs 虫洞态 二选一 -->

                        <!-- B-1. 虫洞开启中：仅显示关闭虫洞按钮 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Snapshot"/>
                                                <Condition Binding="{Binding SelectedSpacetimeNode.IsWormhole}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <!-- 虫洞状态提示 -->
                            <Border Background="{ui:ThemeResource SystemFillColorCautionBackgroundBrush}"
            CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Link24" FontSize="14" Foreground="#FFD700"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_StateWormholeActive}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#FFD700" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- 关闭虫洞 -->
                            <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
               Padding="10,8" Appearance="Caution"
               Command="{Binding CloseWormholeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="LinkDismiss24" FontSize="16"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnCloseWormhole}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>

                        <!-- B-2. 正常态：穿梭、虫洞、平行、收束、删除 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SelectedSpacetimeNode.NodeType}" Value="Snapshot"/>
                                                <Condition Binding="{Binding SelectedSpacetimeNode.IsWormhole}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
               Padding="10,8" Command="{Binding TeleportCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PersonRunning20" FontSize="16"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnTravel}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
               Padding="10,8" Command="{Binding OpenWormholeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Link24" FontSize="16"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnOpenWormhole}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
               Padding="10,8" Command="{Binding ParallelSpacetimeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="BranchFork24" FontSize="16"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnParallelUniverse}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
               Padding="10,8" Command="{Binding ConvergenceCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowReply24" FontSize="16"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnConverge}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
           Padding="10,8" Appearance="Danger" Command="{Binding AnnihilateCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                                    <TextBlock Text="{x:Static properties:Resources.VmSpacetimeSettings_BtnDelete}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>

                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>