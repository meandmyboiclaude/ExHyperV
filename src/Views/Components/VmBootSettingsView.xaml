<UserControl xmlns:properties="clr-namespace:ExHyperV.Properties" x:Class="ExHyperV.Views.Components.VmBootSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:ExHyperV.Behaviors"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,20,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Glyph="&#xF2C7;" FontFamily="{DynamicResource SegoeFluentIcons}" FontSize="22" Margin="0,0,12,0" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Static properties:Resources.VmBootSettings_TitleBootOrder}" FontSize="20" FontWeight="Normal" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{x:Static properties:Resources.VmBootSettings_HintDragToAdjust}" FontSize="13" Opacity="0.6" Margin="0,6,0,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
            <ui:Button Grid.Column="1" Appearance="Transparent" Padding="8" Command="{Binding GoBackToDashboardCommand}">
                <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="20"/>
            </ui:Button>
        </Grid>

        <ListBox x:Name="BootListBox" 
                 Grid.Row="1" 
                 Margin="24,4,24,24" 
                 Background="Transparent" 
                 BorderThickness="0"
                 ItemsSource="{Binding SelectedVm.BootOrderItems}"
                 AllowDrop="True"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 IsHitTestVisible="{Binding SelectedVm.CanChangeBootOrder}">

            <b:Interaction.Behaviors>
                <behaviors:ListBoxDragDropBehavior 
                    MoveItemCommand="{Binding ReorderBootItemCommand}"
                    DropCompletedCommand="{Binding SaveBootOrderCommand}"/>
            </b:Interaction.Behaviors>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel x:Name="ItemsPanel" IsItemsHost="True">
                        <b:Interaction.Behaviors>
                            <b:FluidMoveBehavior AppliesTo="Children" Duration="0:0:0.3">
                                <b:FluidMoveBehavior.EaseY>
                                    <CubicEase EasingMode="EaseOut"/>
                                </b:FluidMoveBehavior.EaseY>
                            </b:FluidMoveBehavior>
                        </b:Interaction.Behaviors>
                    </StackPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="OuterBorder" Background="Transparent" BorderThickness="0">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="MainBorder" 
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="18,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ui:FontIcon Grid.Column="0" 
                                         Glyph="{Binding Icon}" 
                                         FontSize="20" 
                                         Margin="0,0,18,0"
                                         FontFamily="{DynamicResource SegoeFluentIcons}"
                                         Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Medium" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="14" Opacity="0.5" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <ui:FontIcon Grid.Column="2" 
                                         Glyph="&#xE700;" 
                                         FontFamily="{DynamicResource SegoeFluentIcons}" 
                                         FontSize="18" 
                                         Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding DataContext.SelectedVm.CanChangeBootOrder, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False">
                            <Setter TargetName="MainBorder" Property="Opacity" Value="0.6" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>